# ─────────────────────────────────────────────────────────────────────────────
# BrainScan AI — Environment configuration
# Copy this file to .env and adjust values.
# .env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins. Use "*" only in dev.
BRAINSCAN_CORS_ORIGINS=*

# Optional API key required on every endpoint (X-API-Key header).
# Leave empty to disable auth.
BRAINSCAN_API_KEY=

# Rate limiting (requests per minute per IP). 0 = disabled.
BRAINSCAN_RATE_LIMIT=60

# Set to "1" to fully disable rate limiting (e.g. for tests).
BRAINSCAN_DISABLE_RATELIMIT=0

# ── Model ────────────────────────────────────────────────────────────────────
BRAINSCAN_MODEL_PATH=models/final_model_20251106_142153.pth

# ── Logging ──────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
BRAINSCAN_LOG_LEVEL=INFO
