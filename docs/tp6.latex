% ════════════════════════════════════════════════════════════════════════
\chapter{Suivi des expériences et difficultés rencontrées}

\section{Tableau récapitulatif des expériences}

\begin{table}[H]
\centering
\caption{Suivi détaillé des expériences (logs/experiments.csv)}
\scriptsize
\begin{tabularx}{\textwidth}{|c|X|X|X|X|X|}
\hline
\rowcolor{navy!10}
\textbf{ID} & \textbf{Modèle} & \textbf{Paramètres modifiés} & \textbf{Acc val} & \textbf{Acc test} & \textbf{Observations} \\
\hline
E1 & CNN custom (4 conv) & Aucun (baseline) & 78\% & 76\% & Overfit dès l'époque 25 ; pas de transfer learning \\
\hline
E2 & ResNet50 (tout entraînable) & Backbone non gelé · lr=$10^{-3}$ & 91\% & 89\% & Instabilité Stage 1, oscillations val loss \\
\hline
E3 & ResNet50 2-stages & Freeze + 2 stages LR & 97.8\% & 97.5\% & Courbes lisses, convergence vers ép. 35 \\
\hline
E3b & ResNet50 2-stages + dropout 0.6 & Dropout augmenté & 96.9\% & 96.4\% & Trop de régularisation, légère sous-perf. \\
\hline
E3c & ResNet50 2-stages + LR Stage 2 = $5\!\times\!10^{-5}$ & LR2 halvé & 97.6\% & 97.3\% & Convergence trop lente, gain marginal \\
\hline
