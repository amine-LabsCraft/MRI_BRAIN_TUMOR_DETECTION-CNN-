\textbf{Hyperparamètre} & \textbf{Valeur} \\
\hline
\endfirsthead
\hline
\rowcolor{navy!10}
\textbf{Hyperparamètre} & \textbf{Valeur} \\
\hline
\endhead
\hline
\endfoot
Taille du batch (batch size)        & 24 \\
\hline
Learning rate Stage 1               & $1 \times 10^{-3}$ \\
\hline
Learning rate Stage 2               & $1 \times 10^{-4}$ \\
